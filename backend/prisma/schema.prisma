// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Data model for a job application
model Application {
  id           String   @id @default(uuid()) // Unique identifier for each application
  company_name String   // Name of the company applied to
  job_title    String   // Title of the position
  job_type     String   // Can be "Internship", "Full-time", or "Part-time"
  status       String   // Can be "Applied", "Interviewing", "Offer", or "Rejected"
  applied_date DateTime // The date the application was submitted
  notes        String?  // Optional extra notes
  createdAt    DateTime @default(now()) // Automatically set when created
  updatedAt    DateTime @updatedAt // Automatically updated when modified
}
